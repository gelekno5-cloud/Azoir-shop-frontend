<script>
(function () {
  /* ── Supabase config (anon/public key only — safe to expose in browser) ── */
  var SUPABASE_URL        = {{ section.settings.supabase_url        | default: '' | json }};
  var SUPABASE_KEY        = {{ section.settings.supabase_anon_key   | default: '' | json }};
  var SUPABASE_BUCKET     = {{ section.settings.supabase_bucket     | default: 'commission-uploads' | json }};
  var EDGE_FUNCTION_URL   = {{ section.settings.edge_function_url   | default: '' | json }};
  var DESIGN_FEE_REDIRECT = {{ section.settings.design_fee_redirect | default: '/pages/design-fee' | json }};

  var MAX_FILES = 5;
  var MAX_SIZE  = 10 * 1024 * 1024; // 10 MB per file

  /* ── Element refs ─────────────────────────────────────────────────────── */
  var form         = document.getElementById('cr2c-form');
  var formError    = document.getElementById('cr2c-form-error');
  var zone         = document.getElementById('cr2c-upload-zone');
  var fileInput    = document.getElementById('cr2c-file-input');
  var previews     = document.getElementById('cr2c-upload-previews');
  var hiddenRef    = document.getElementById('cr2c-reference-links');
  var errorEl      = document.getElementById('cr2c-upload-error');
  var stoneBtns    = document.querySelectorAll('#cr2c-stone-btns .cr-stone-btn');
  var stonesHidden = document.getElementById('cr2c-stones-hidden');
  var stonesOther  = document.getElementById('cr2c-stones-other');

  var uploadedFiles = []; // { id, file }
  var nextId = 0;

  /* ── Edit mode: pre-fill form from Supabase if edit_request_id in URL ─── */
  (function () {
    var editId = new URLSearchParams(window.location.search).get('edit_request_id');
    if (!editId || !SUPABASE_URL || !SUPABASE_KEY) return;

    var apiUrl = SUPABASE_URL.replace(/\/$/, '') +
      '/rest/v1/quote_requests?id=eq.' + encodeURIComponent(editId) +
      '&select=customer_name,email,phone,country,contact_method,notes,metal,stones&limit=1';

    fetch(apiUrl, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY }
    })
      .then(function (res) { return res.json(); })
      .then(function (rows) {
        if (!rows || !rows.length) return;
        var r = rows[0];

        function setVal(id, val) {
          var el = document.getElementById(id);
          if (el && val) el.value = val;
        }

        setVal('cr2c-name',    r.customer_name);
        setVal('cr2c-email',   r.email);
        setVal('cr2c-country', r.country);
        /* Pre-fill phone: try to strip known country code */
        if (r.phone) {
          var phoneCodeEl   = document.getElementById('cr2c-phone-code');
          var phoneNumberEl = document.getElementById('cr2c-phone-number');
          var phoneHidden   = document.getElementById('cr2c-phone');
          var stored = r.phone.trim();
          var codeMatched = false;
          if (phoneCodeEl && phoneNumberEl) {
            Array.from(phoneCodeEl.options).forEach(function (opt) {
              if (!codeMatched && opt.value && stored.startsWith(opt.value + ' ')) {
                phoneCodeEl.value   = opt.value;
                phoneNumberEl.value = stored.slice(opt.value.length + 1);
                codeMatched = true;
              }
            });
            if (!codeMatched) phoneNumberEl.value = stored;
          }
          if (phoneHidden) phoneHidden.value = stored;
        }
        setVal('cr2c-describe',       r.notes);
        setVal('cr2c-metal',          r.metal);
        /* Pre-fill contact method buttons */
        if (r.contact_method) {
          var contactBtns = document.querySelectorAll('#cr2c-contact-btns .cr-contact-btn');
          contactBtns.forEach(function (btn) {
            if (btn.dataset.value === r.contact_method) {
              btn.classList.add('is-active');
              document.getElementById('cr2c-contact-method').value = r.contact_method;
            }
          });
        }

        /* Stone buttons */
        if (r.stones) {
          var btns = document.querySelectorAll('#cr2c-stone-btns .cr-stone-btn');
          var matched = false;
          btns.forEach(function (btn) {
            if (btn.dataset.value === r.stones) {
              btn.classList.add('is-active');
              document.getElementById('cr2c-stones-hidden').value = r.stones;
              matched = true;
            }
          });
          if (!matched) {
            /* Custom stone value */
            setVal('cr2c-stones-other', r.stones);
            document.getElementById('cr2c-stones-hidden').value = r.stones;
          }
        }
      })
      .catch(function (err) { console.warn('Edit pre-fill failed:', err); });
  })();

  /* ── Error display helpers ────────────────────────────────────────────── */
  function showUploadError(msg) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.hidden = !msg;
  }
  function showFormError(msg) {
    if (!formError) return;
    formError.textContent = msg;
    formError.hidden = !msg;
    if (msg) formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* ── Inline field validation helpers ─────────────────────────────────── */
  function setFieldError(el, msg) {
    if (!el) return;
    el.classList.add('is-invalid');
    /* Shake */
    el.classList.remove('is-shaking');
    void el.offsetWidth; /* reflow to restart animation */
    el.classList.add('is-shaking');
    el.addEventListener('animationend', function () { el.classList.remove('is-shaking'); }, { once: true });
    /* Error message */
    var errEl = el.parentElement.querySelector('.commission-form__field-error');
    if (!errEl) {
      errEl = document.createElement('p');
      errEl.className = 'commission-form__field-error';
      el.parentElement.appendChild(errEl);
    }
    errEl.textContent = msg;
    requestAnimationFrame(function () { errEl.classList.add('is-visible'); });
  }

  function clearFieldError(el) {
    if (!el) return;
    el.classList.remove('is-invalid', 'is-shaking');
    var errEl = el.parentElement && el.parentElement.querySelector('.commission-form__field-error');
    if (errEl) {
      errEl.classList.remove('is-visible');
      setTimeout(function () { if (errEl.parentElement) errEl.parentElement.removeChild(errEl); }, 200);
    }
  }

  function attachClearOnInput(el) {
    if (!el) return;
    var ev = (el.tagName === 'SELECT') ? 'change' : 'input';
    el.addEventListener(ev, function () { clearFieldError(el); }, { once: true });
  }

  function validateFields() {
    var nameEl    = form.querySelector('[name="name"]');
    var emailEl   = form.querySelector('[name="email"]');
    var metalEl   = form.querySelector('[name="metal"]');
    var errors    = [];

    if (!nameEl.value.trim()) {
      setFieldError(nameEl, 'Please enter your full name.');
      attachClearOnInput(nameEl);
      errors.push(nameEl);
    }
    if (!emailEl.value.trim()) {
      setFieldError(emailEl, 'Please enter your email address.');
      attachClearOnInput(emailEl);
      errors.push(emailEl);
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
      setFieldError(emailEl, 'Please enter a valid email address.');
      attachClearOnInput(emailEl);
      errors.push(emailEl);
    }
    if (!metalEl.value) {
      setFieldError(metalEl, 'Please select a metal.');
      attachClearOnInput(metalEl);
      errors.push(metalEl);
    }

    if (errors.length > 0) {
      errors[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
      errors[0].focus();
    }

    return errors.length === 0;
  }

  /* ── Zone: click / keyboard open file picker ──────────────────────────── */
  if (zone && fileInput) {
    zone.addEventListener('click', function () { fileInput.click(); });
    zone.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
    });

    /* Drag & drop */
    zone.addEventListener('dragover', function (e) {
      e.preventDefault();
      zone.classList.add('is-dragover');
    });
    ['dragleave', 'dragend'].forEach(function (ev) {
      zone.addEventListener(ev, function () { zone.classList.remove('is-dragover'); });
    });
    zone.addEventListener('drop', function (e) {
      e.preventDefault();
      zone.classList.remove('is-dragover');
      addFiles(Array.from(e.dataTransfer.files));
    });

    /* File picker change */
    fileInput.addEventListener('change', function () {
      addFiles(Array.from(fileInput.files));
      fileInput.value = ''; // reset so same file can be re-added after removal
    });
  }

  /* ── Add files to the queue ───────────────────────────────────────────── */
  function addFiles(newFiles) {
    showUploadError('');
    var imageFiles = newFiles.filter(function (f) {
      if (!f.type.startsWith('image/')) {
        showUploadError('Only image files are accepted (JPG, PNG, WEBP).');
        return false;
      }
      if (f.size > MAX_SIZE) {
        showUploadError('"' + f.name + '" exceeds the 10 MB limit.');
        return false;
      }
      return true;
    });

    var slots = MAX_FILES - uploadedFiles.length;
    if (imageFiles.length > slots) {
      showUploadError('Maximum ' + MAX_FILES + ' photos allowed. Only the first ' + slots + ' were added.');
      imageFiles = imageFiles.slice(0, slots);
    }

    imageFiles.forEach(function (file) {
      var id = nextId++;
      uploadedFiles.push({ id: id, file: file });
      renderPreview(id, file);
    });

    syncZoneState();
  }

  /* ── Render a thumbnail preview card ─────────────────────────────────── */
  function renderPreview(id, file) {
    if (!previews) return;
    previews.hidden = false;
    var reader = new FileReader();
    reader.onload = function (e) {
      var item = document.createElement('div');
      item.className = 'cr-upload__item';
      item.dataset.id = id;
      item.innerHTML =
        '<img src="' + e.target.result + '" alt="' + file.name + '" class="cr-upload__thumb">' +
        '<div class="cr-upload__item-overlay"></div>' +
        '<button type="button" class="cr-upload__remove" aria-label="Remove ' + file.name + '">' +
          '<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>' +
        '</button>';
      item.querySelector('.cr-upload__remove').addEventListener('click', function () {
        uploadedFiles = uploadedFiles.filter(function (f) { return f.id !== id; });
        item.remove();
        if (uploadedFiles.length === 0 && previews) previews.hidden = true;
        syncZoneState();
        showUploadError('');
      });
      previews.appendChild(item);
    };
    reader.readAsDataURL(file);
  }

  /* ── Toggle zone "full" state when limit is reached ──────────────────── */
  function syncZoneState() {
    if (zone) zone.classList.toggle('is-full', uploadedFiles.length >= MAX_FILES);
  }

  /* ── Upload one file to Supabase Storage, returns promise<publicUrl|null> */
  function uploadToSupabase(file) {
    var ext  = file.name.split('.').pop().toLowerCase();
    var path = 'commissions/' + Date.now() + '-' + Math.random().toString(36).slice(2, 9) + '.' + ext;
    var url  = SUPABASE_URL.replace(/\/$/, '') + '/storage/v1/object/' + SUPABASE_BUCKET + '/' + path;

    return fetch(url, {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + SUPABASE_KEY,
        'apikey': SUPABASE_KEY,
        'Content-Type': file.type || 'application/octet-stream',
        'x-upsert': 'false'
      },
      body: file
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) return null;
        return SUPABASE_URL.replace(/\/$/, '') + '/storage/v1/object/public/' + SUPABASE_BUCKET + '/' + path;
      })
      .catch(function () { return null; });
  }

