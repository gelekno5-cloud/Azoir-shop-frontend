{%- comment -%} Brand Story — Azoir {%- endcomment -%}
<link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}"></noscript>

<section class="bs-section">
  <div class="bs-container">

    <div class="bs-content">
      <span class="bs-eyebrow">OUR STORY</span>

      <h2 class="bs-statement">
        Every piece begins<br>as a conversation.
      </h2>

      <div class="bs-body" id="bs-body">
        <p>
          Azoir was founded in New York with a single premise: that the most meaningful jewellery is made for one person, by hand, with full intention. Not produced. Not catalogued. Made.
        </p>
        <p>
          Each commission starts with a conversation — about the person who will wear the piece, the moment it marks, the feeling it should carry. Our jewellers then translate that into metal and stone, working through sketches and iterations until every detail is exactly right.
        </p>
        <p>
          We work in 18k gold, platinum, and sterling silver. We source conflict-free stones. And we never rush a piece that is meant to last a lifetime.
        </p>
      </div>
      <button class="bs-read-more" id="bs-read-more" aria-expanded="false">Read more</button>

      <a href="{{ section.settings.cta_url | default: '/pages/about' }}" class="bs-cta">
        {{ section.settings.cta_text | default: 'About the atelier' }}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="bs-visual" aria-hidden="true">
      <div class="bs-visual__frame">

        {%- if section.settings.video != blank -%}
          <video
            class="bs-visual__media"
            autoplay muted loop playsinline preload="metadata"
          >
            {%- for source in section.settings.video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>

        {%- elsif section.settings.image != blank -%}
          <img
            class="bs-visual__media"
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >

        {%- else -%}
          <svg viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="bs-visual__svg">
            <circle cx="200" cy="240" r="120" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.10"/>
            <circle cx="200" cy="240" r="88"  stroke="#0a0a0a" stroke-width="1"   fill="none" opacity="0.07"/>
            <circle cx="200" cy="240" r="56"  stroke="#0a0a0a" stroke-width="0.8" fill="none" opacity="0.05"/>
            <path d="M114 240 Q200 130 286 240" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.18"/>
            <path d="M124 235 Q200 145 276 235" stroke="#0a0a0a" stroke-width="0.8" fill="none" opacity="0.10"/>
            <circle cx="200" cy="125" r="5" stroke="#0a0a0a" stroke-width="1.2" fill="none" opacity="0.22"/>
            <circle cx="161" cy="136" r="3.5" stroke="#0a0a0a" stroke-width="1" fill="none" opacity="0.16"/>
            <circle cx="239" cy="136" r="3.5" stroke="#0a0a0a" stroke-width="1" fill="none" opacity="0.16"/>
            <text x="200" y="408" text-anchor="middle" fill="#0a0a0a" font-size="9" letter-spacing="4" opacity="0.18" font-family="sans-serif">AZOIR &amp; CO.</text>
            <text x="200" y="424" text-anchor="middle" fill="#0a0a0a" font-size="7" letter-spacing="2" opacity="0.12" font-family="sans-serif">NEW YORK</text>
          </svg>
        {%- endif -%}

        <div class="bs-visual__tag">
          <span class="bs-visual__tag-line">Handcrafted</span>
          <span class="bs-visual__tag-line">in New York</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Hide read-more button on desktop */
  @media (min-width: 601px) { #bs-read-more { display: none; } }
</style>
<script>
(function () {
  var btn  = document.getElementById('bs-read-more');
  var body = document.getElementById('bs-body');
  if (!btn || !body) return;
  btn.addEventListener('click', function () {
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    body.classList.toggle('bs-body--expanded', !expanded);
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.textContent = expanded ? 'Read more' : 'Read less';
  });
})();
</script>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    { "type": "video",       "id": "video",    "label": "Video (optional)", "info": "Upload an .mp4 video. Takes priority over image." },
    { "type": "image_picker","id": "image",    "label": "Image (optional)", "info": "Used if no video is set." },
    { "type": "url",         "id": "cta_url",  "label": "CTA URL" },
    { "type": "text",        "id": "cta_text", "label": "CTA text", "default": "About the atelier" }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
