{%- comment -%} Press — Azoir {%- endcomment -%}
<link rel="stylesheet" href="{{ 'pages.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'pages.css' | asset_url }}"></noscript>

<section class="press-hero">
  <div class="ap-container">
    <span class="ap-eyebrow">Press &amp; Recognition</span>
    <h1 class="press-hero__title">As seen in.</h1>
    <p class="press-hero__sub">Azoir &amp; Co. has been featured by editors, stylists, and publications covering fine jewellery, bespoke craft, and modern luxury.</p>
  </div>
</section>

<section class="press-logos">
  <div class="ap-container">
    <div class="press-logos__grid">
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Vogue">
          <text x="80" y="32" text-anchor="middle" fill="#0a0a0a" font-size="20" letter-spacing="6" font-family="Georgia, serif" opacity="0.55">VOGUE</text>
        </svg>
      </div>
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Harper's Bazaar">
          <text x="80" y="22" text-anchor="middle" fill="#0a0a0a" font-size="9" letter-spacing="4" font-family="Georgia, serif" opacity="0.55">HARPER'S</text>
          <text x="80" y="38" text-anchor="middle" fill="#0a0a0a" font-size="9" letter-spacing="4" font-family="Georgia, serif" opacity="0.55">BAZAAR</text>
        </svg>
      </div>
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Architectural Digest">
          <text x="80" y="22" text-anchor="middle" fill="#0a0a0a" font-size="9.5" letter-spacing="3.5" font-family="Georgia, serif" opacity="0.55">ARCHITECTURAL</text>
          <text x="80" y="38" text-anchor="middle" fill="#0a0a0a" font-size="9.5" letter-spacing="3.5" font-family="Georgia, serif" opacity="0.55">DIGEST</text>
        </svg>
      </div>
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Town & Country">
          <text x="80" y="22" text-anchor="middle" fill="#0a0a0a" font-size="8.5" letter-spacing="3.5" font-family="Georgia, serif" opacity="0.55">TOWN &amp;</text>
          <text x="80" y="38" text-anchor="middle" fill="#0a0a0a" font-size="8.5" letter-spacing="3.5" font-family="Georgia, serif" opacity="0.55">COUNTRY</text>
        </svg>
      </div>
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="The Knot">
          <text x="80" y="32" text-anchor="middle" fill="#0a0a0a" font-size="13" letter-spacing="5" font-family="Georgia, serif" opacity="0.55">THE KNOT</text>
        </svg>
      </div>
      <div class="press-logo-item">
        <svg viewBox="0 0 160 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Brides">
          <text x="80" y="33" text-anchor="middle" fill="#0a0a0a" font-size="18" letter-spacing="6" font-family="Georgia, serif" opacity="0.55">BRIDES</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<section class="press-quotes">
  <div class="ap-container">
    <h2 class="ap-section-title">What they said</h2>
    <div class="press-quotes__grid">

      <blockquote class="press-quote">
        <p class="press-quote__text">"A new standard for bespoke jewellery — rigorous craft, transparent process, and a design sensibility that feels genuinely modern without chasing trends."</p>
        <footer class="press-quote__source">
          <span class="press-quote__pub">Vogue</span>
          <span class="press-quote__label">Fine Jewellery Feature</span>
        </footer>
      </blockquote>

      <blockquote class="press-quote">
        <p class="press-quote__text">"Azoir has figured out how to make the custom process feel effortless. The result is jewellery that looks like it was always meant to exist."</p>
        <footer class="press-quote__source">
          <span class="press-quote__pub">Harper's Bazaar</span>
          <span class="press-quote__label">The New Bespoke</span>
        </footer>
      </blockquote>

      <blockquote class="press-quote">
        <p class="press-quote__text">"What sets Azoir apart isn't the quality of the metalwork — though that's exceptional — it's the clarity of thought behind every piece."</p>
        <footer class="press-quote__source">
          <span class="press-quote__pub">Town &amp; Country</span>
          <span class="press-quote__label">American Luxury Report</span>
        </footer>
      </blockquote>

    </div>
  </div>
</section>

<section class="press-contact">
  <div class="ap-container">
    <div class="press-contact__inner">
      <span class="ap-eyebrow">Press enquiries</span>
      <h2 class="press-contact__title">Working on a story?</h2>
      <p>We welcome editorial collaborations, product loans, and interview requests. Reach our press contact directly — we respond within 48 hours.</p>
      <a href="/pages/contact" class="press-contact__btn">press@azoir.co &rarr;</a>
    </div>
  </div>
</section>

<section class="ap-cta-band">
  <div class="ap-container">
    <h2 class="ap-cta-band__title">Commission something worth writing about.</h2>
    <p class="ap-cta-band__sub">Bespoke jewellery, made in New York. The first conversation is always free.</p>
    <a href="/pages/start-your-piece" class="ap-cta-band__btn">Start your commission</a>
  </div>
</section>

{% schema %}
{
  "name": "Press",
  "settings": [],
  "presets": [{ "name": "Press" }]
}
{% endschema %}
