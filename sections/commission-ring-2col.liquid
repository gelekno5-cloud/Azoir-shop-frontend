      'Sri Lanka': '+94', 'Sudan': '+249', 'Suriname': '+597', 'Sweden': '+46',
      'Switzerland': '+41', 'Syria': '+963', 'Taiwan': '+886', 'Tajikistan': '+992',
      'Tanzania': '+255', 'Thailand': '+66', 'Timor-Leste': '+670', 'Togo': '+228',
      'Tonga': '+676', 'Trinidad and Tobago': '+1', 'Tunisia': '+216', 'Turkey': '+90',
      'Turkmenistan': '+993', 'Tuvalu': '+688', 'Uganda': '+256', 'Ukraine': '+380',
      'United Arab Emirates': '+971', 'United Kingdom': '+44', 'United States': '+1',
      'Uruguay': '+598', 'Uzbekistan': '+998', 'Vanuatu': '+678', 'Vatican City': '+379',
      'Venezuela': '+58', 'Vietnam': '+84', 'Yemen': '+967', 'Zambia': '+260',
      'Zimbabwe': '+263'
    };

    /* Auto-fill phone code when country changes */
    if (countryEl) {
      countryEl.addEventListener('change', function () {
        var dial = dialMap[countryEl.value];
        if (dial) {
          /* Find matching option in phone code select */
          var matched = Array.from(codeEl.options).find(function (opt) {
            return opt.value === dial;
          });
          if (matched) codeEl.value = dial;
          sync();
        }
      });
    }

    function sync() {
      var num = numberEl.value.trim();
      hiddenEl.value = num ? (codeEl.value + ' ' + num) : '';
    }
    codeEl.addEventListener('change', sync);
    numberEl.addEventListener('input', sync);
  })();

  /* ── Contact method buttons ──────────────────────────────────────────── */
  var contactBtns   = document.querySelectorAll('#cr2c-contact-btns .cr-contact-btn');
  var contactHidden = document.getElementById('cr2c-contact-method');
  contactBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      contactBtns.forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      contactHidden.value = btn.dataset.value;
    });
  });

  /* ── Stone buttons ────────────────────────────────────────────────────── */
  stoneBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var already = btn.classList.contains('is-active');
      stoneBtns.forEach(function (b) { b.classList.remove('is-active'); });
      /* Clicking the active button again deselects it */
      if (already) {
        stonesHidden.value = '';
      } else {
        btn.classList.add('is-active');
        stonesHidden.value = btn.dataset.value;
        /* Clear the "other" text field when a preset button is picked */
        if (stonesOther) stonesOther.value = '';
      }
    });
  });

  /* Typing in "other" clears the button selection */
  if (stonesOther) {
    stonesOther.addEventListener('input', function () {
      if (stonesOther.value.trim()) {
        stoneBtns.forEach(function (b) { b.classList.remove('is-active'); });
        stonesHidden.value = stonesOther.value.trim();
      } else {
        stonesHidden.value = '';
      }
    });
  }

  /* ── Form submit → Edge Function → redirect to design-fee page ───────── */
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      showFormError('');
      showUploadError('');

      var nameEl    = form.querySelector('[name="name"]');
      var emailEl   = form.querySelector('[name="email"]');
      var notesEl   = form.querySelector('[name="notes"]');
      var metalEl   = form.querySelector('[name="metal"]');
      var stonesEl  = form.querySelector('[name="stones"]');
      var countryEl = form.querySelector('[name="country"]');
      var phoneEl   = form.querySelector('[name="phone"]');
      var methodEl  = form.querySelector('[name="contact_method"]');

      /* Client-side validation */
      if (!validateFields()) return;
      if (!EDGE_FUNCTION_URL) { showFormError('Submission is not configured yet. Please contact us directly.'); return; }

      var submitBtn = form.querySelector('.commission-rings-form__submit');
      var origLabel = submitBtn ? submitBtn.textContent : '';
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Uploading\u2026'; }

      /* Upload photos first (if any), then POST to Edge Function */
      var uploadPromise = (uploadedFiles.length && SUPABASE_URL && SUPABASE_KEY)
        ? Promise.all(uploadedFiles.map(function (f) { return uploadToSupabase(f.file); }))
        : Promise.resolve([]);

      uploadPromise
        .then(function (urls) {
          var photoUrls = urls.filter(Boolean);
          if (submitBtn) submitBtn.textContent = 'Submitting\u2026';

          var payload = {
            customer_name:   nameEl.value.trim(),
            email:           emailEl.value.trim(),
            phone:           phoneEl   ? phoneEl.value.trim()   : '',
            country:         countryEl ? countryEl.value.trim() : '',
            contact_method:  methodEl  ? methodEl.value         : '',
            notes:           notesEl   ? notesEl.value.trim()   : '',
            metal:           metalEl   ? metalEl.value          : '',
            stones:          stonesEl  ? stonesEl.value         : '',
            reference_links: photoUrls.join(', ')
          };

          /* If editing an existing request, include its ID so the edge function updates instead of inserts */
          var editRequestId = new URLSearchParams(window.location.search).get('edit_request_id');
          if (editRequestId) payload.request_id = editRequestId;

          return fetch(EDGE_FUNCTION_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
        })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (!data.success) throw new Error(data.error || 'Submission failed.');
          window.location.href = DESIGN_FEE_REDIRECT + '?request_id=' + encodeURIComponent(data.request_id) + '&from=' + encodeURIComponent(window.location.href);
        })
        .catch(function (err) {
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = origLabel; }
          showFormError(err.message || 'Something went wrong. Please try again.');
        });
    });
  }

  /* ── Rotating terminal-style placeholder ─────────────────────────────── */
  (function () {
    var ta = document.getElementById('cr2c-describe');
    if (!ta) return;

    var phrases = [
      'Something elegant for my wedding day, maybe a gold ring with a diamond\u2026',
      'A simple but beautiful engagement ring with a classic look\u2026',
      'A minimalist ring with a small diamond and a clean band\u2026',
      'A vintage inspired ring with a romantic feel\u2026',
      'A modern ring with a unique center stone\u2026',
      'A delicate ring with a thin band and a sparkling diamond\u2026'
    ];

    var TYPE_SPEED   = 28;  // ms per character when typing
    var DELETE_SPEED = 12;  // ms per character when deleting
    var HOLD_PAUSE   = 1400; // ms to hold the full phrase before deleting
    var NEXT_PAUSE   = 250;  // ms pause between phrases

    var phraseIndex = 0;
    var charIndex   = 0;
    var isDeleting  = false;
    var timer       = null;

    function tick() {
      /* Stop animating if the user has focused or typed in the field */
      if (document.activeElement === ta || ta.value !== '') return;

      var current = phrases[phraseIndex];

      if (!isDeleting) {
        /* Typing forward */
        charIndex++;
        ta.placeholder = current.slice(0, charIndex);

        if (charIndex === current.length) {
          /* Full phrase shown — hold, then start deleting */
          isDeleting = true;
          timer = setTimeout(tick, HOLD_PAUSE);
          return;
        }
      } else {
        /* Deleting backward */
        charIndex--;
        ta.placeholder = current.slice(0, charIndex);

        if (charIndex === 0) {
          /* Phrase fully deleted — move to next */
          isDeleting  = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          timer = setTimeout(tick, NEXT_PAUSE);
          return;
        }
      }

      timer = setTimeout(tick, isDeleting ? DELETE_SPEED : TYPE_SPEED);
    }

    /* Clear placeholder instantly when field is focused */
    ta.addEventListener('focus', function () {
      clearTimeout(timer);
      ta.placeholder = '';
    });

    /* Resume animation when user blurs the field (if they left it empty) */
    ta.addEventListener('blur', function () {
      if (ta.value === '') {
        charIndex   = 0;
        isDeleting  = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        clearTimeout(timer);
        timer = setTimeout(tick, NEXT_PAUSE);
      }
    });

    /* Kick off */
    timer = setTimeout(tick, 800);
  })();

  /* ── Slideshow ────────────────────────────────────────────────────────── */
  var slideshow = document.querySelector('[data-slideshow]');
  if (!slideshow) return;
  var slides = slideshow.querySelectorAll('.commission-two-col__slide');
  var dots   = slideshow.querySelectorAll('.commission-two-col__dot');
  if (slides.length < 2) return;

  var current = 0;

  function goTo(index) {
    current = ((index % slides.length) + slides.length) % slides.length;
    slides.forEach(function (s, n) { s.classList.toggle('is-active', n === current); });
    dots.forEach(function (d, n)   { d.classList.toggle('is-active', n === current); });
  }

  dots.forEach(function (dot, i) { dot.addEventListener('click', function () { goTo(i); }); });

  var prevBtn = slideshow.querySelector('[data-slide-prev]');
  var nextBtn = slideshow.querySelector('[data-slide-next]');
  if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

  var autoplay = setInterval(function () { goTo(current + 1); }, 5000);
  slideshow.addEventListener('mouseenter', function () { clearInterval(autoplay); });

  /* Keep native videos playing silently */
  slideshow.querySelectorAll('.commission-two-col__video-native').forEach(function (video) {
    video.controls = false;
    video.muted = true;
    video.playsInline = true;
    video.addEventListener('pause', function () { video.play(); });
    video.addEventListener('click', function (e) { e.preventDefault(); video.play(); });
  });
})();
</script>

