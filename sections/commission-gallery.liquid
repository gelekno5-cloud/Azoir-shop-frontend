<section class="commission-page commission-gallery" id="commission-gallery">
  <div class="commission-gallery__inner">
    {% if section.settings.heading != blank %}
      <h2 class="commission-gallery__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% assign card_blocks = section.blocks | where: 'type', 'card' %}
    {% if card_blocks.size > 0 %}
      <div
        class="commission-gallery__grid commission-gallery__grid--cols-{{ section.settings.columns_desktop }}"
      >
        {% for block in card_blocks %}
          <div class="commission-gallery__card" {{ block.shopify_attributes }}>
            <div class="commission-gallery__card-image">
              {% if block.settings.image != blank %}
                {% assign card_alt = block.settings.title | default: 'Commission' | escape %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_alt }}
              {% else %}
                <div style="width:100%;height:100%;background:#eee;display:flex;align-items:center;justify-content:center;color:#999;font-size:0.875rem;">Image</div>
              {% endif %}
            </div>
            <div class="commission-gallery__card-body">
              {% if block.settings.title != blank %}
                <h3 class="commission-gallery__card-title">{{ block.settings.title | escape }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="commission-gallery__card-text">{{ block.settings.text | escape }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Commission Gallery",
  "tag": "section",
  "class": "section-commission-gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent Commissions"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Commission Gallery",
      "blocks": [
        { "type": "card", "settings": { "title": "Solitaire", "text": "Classic yellow gold with a single stone." } },
        { "type": "card", "settings": { "title": "Art Deco", "text": "Platinum band with geometric detail." } },
        { "type": "card", "settings": { "title": "Custom Band", "text": "Hand-textured rose gold wedding band." } }
      ]
    }
  ]
}
{% endschema %}
