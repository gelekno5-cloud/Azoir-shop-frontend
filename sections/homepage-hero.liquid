{% comment %} sections/homepage-hero.liquid — Azoir scroll-driven hero v1 {% endcomment %}

<div
  id="azh-root"
  class="azh-root"
  data-frames-base="{{ section.settings.frames_base_url | escape }}"
  data-frame-count="{{ section.settings.frame_count }}"
>
  <div class="azh-sticky" id="azh-sticky">

    <div class="azh-hero-layer" id="azh-hero-layer">
      <div class="azh-hero-inner">
        <span class="azh-label">001 / Azoir & Co</span>
        <h1 class="azh-hero-heading">
          <span class="azh-word">NYC Handcrafted.</span>
          <span class="azh-word">Design By You.</span>
        </h1>
        <p class="azh-hero-tagline">Luxury jewellery, handcrafted to order.</p>
        <div class="azh-scroll-hint" aria-hidden="true">
          <span>Scroll to discover</span>
          <svg width="14" height="20" viewBox="0 0 14 20" fill="none">
            <path d="M7 3v14M2 12l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>

    <canvas id="azh-canvas" aria-hidden="true"></canvas>
    <div id="azh-dark-overlay" aria-hidden="true"></div>

    <div class="azh-marquee-wrap" id="azh-marquee" aria-hidden="true">
      <div class="azh-marquee-text">
        COMMISSION YOUR PIECE &nbsp;&mdash;&nbsp;
        COMMISSION YOUR PIECE &nbsp;&mdash;&nbsp;
        COMMISSION YOUR PIECE &nbsp;&mdash;&nbsp;
        COMMISSION YOUR PIECE &nbsp;&mdash;&nbsp;
      </div>
    </div>

    <div class="azh-sections">

      <section class="azh-section align-left" data-enter="22" data-leave="42" data-animation="slide-left">
        <div class="azh-section-inner">
          <span class="azh-label">002 / Process</span>
          <h2 class="azh-heading">Every piece<br>starts with you</h2>
          <p class="azh-body">We take your vision from first sketch to finished jewellery — entirely bespoke, entirely yours.</p>
        </div>
      </section>

      <section class="azh-section align-right" data-enter="44" data-leave="62" data-animation="slide-right">
        <div class="azh-section-inner">
          <span class="azh-label">003 / Craft</span>
          <h2 class="azh-heading">Handcrafted<br>in precious metal</h2>
          <p class="azh-body">No catalogues. No compromises. Each commission is a collaboration between you and our master jewellers.</p>
        </div>
      </section>

      <section class="azh-section azh-stats" data-enter="64" data-leave="78" data-animation="stagger-up">
        <div class="azh-stats-grid">
          <div class="azh-stat">
            <div class="azh-stat-row">
              <span class="azh-stat-number" data-value="12" data-decimals="0">0</span>
              <span class="azh-stat-suffix">days</span>
            </div>
            <span class="azh-stat-label">to first design</span>
          </div>
          <div class="azh-stat">
            <div class="azh-stat-row">
              <span class="azh-stat-number" data-value="100" data-decimals="0">0</span>
              <span class="azh-stat-suffix">%</span>
            </div>
            <span class="azh-stat-label">custom made</span>
          </div>
          <div class="azh-stat">
            <div class="azh-stat-row">
              <span class="azh-stat-prefix">$</span>
              <span class="azh-stat-number" data-value="59" data-decimals="0">0</span>
            </div>
            <span class="azh-stat-label">design fee</span>
          </div>
        </div>
      </section>

      <section class="azh-section align-right azh-cta-section" data-enter="76" data-leave="100" data-animation="fade-up" data-persist="true">
        <div class="azh-section-inner">
          <span class="azh-label">004 / Begin</span>
          <h2 class="azh-heading">Ready to begin?</h2>
          <p class="azh-body">Tell us what you have in mind.</p>
          <a href="{{ section.settings.cta_url }}" class="azh-cta-btn">
            {{ section.settings.cta_text | escape }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>

    </div>
  </div>
</div>

{{ 'homepage-hero.css' | asset_url | stylesheet_tag }}

<script>
(function () {
  var deps = [
    'https://cdn.jsdelivr.net/npm/lenis@1/dist/lenis.min.js',
    'https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js',
    'https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js',
    {{ 'homepage-hero.js' | asset_url | json }}
  ];
  function loadNext(i) {
    if (i >= deps.length) return;
    if (document.querySelector('script[src="' + deps[i] + '"]')) { loadNext(i + 1); return; }
    var s = document.createElement('script');
    s.src = deps[i];
    s.onload = function () { loadNext(i + 1); };
    document.head.appendChild(s);
  }
  loadNext(0);
})();
</script>

{% schema %}
{
  "name": "Homepage Hero",
  "tag": "section",
  "class": "azh-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "frames_base_url",
      "label": "Frames Base URL",
      "info": "Supabase public storage URL pointing to the folder with frame_0001.webp files. No trailing slash."
    },
    {
      "type": "range",
      "id": "frame_count",
      "label": "Frame Count",
      "min": 10,
      "max": 310,
      "step": 3,
      "default": 190
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Start your commission"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
