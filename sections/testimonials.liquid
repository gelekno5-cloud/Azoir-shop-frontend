    </div>

    <div class="tm-progress" id="tm-progress" aria-hidden="true">
      <div class="tm-progress__bar" id="tm-progress-bar"></div>
    </div>

    <div class="tm-dots" id="tm-dots" aria-hidden="true">
      <span class="tm-dot tm-dot--active" data-index="0"></span>
      <span class="tm-dot" data-index="1"></span>
      <span class="tm-dot" data-index="2"></span>
      <span class="tm-dot" data-index="3"></span>
      <span class="tm-dot" data-index="4"></span>
      <span class="tm-dot" data-index="5"></span>
      <span class="tm-dot" data-index="6"></span>
    </div>

  </div>
</section>

<script>
(function () {
  var slides   = Array.from(document.querySelectorAll('#tm-stage .tm-slide'));
  var dots     = Array.from(document.querySelectorAll('#tm-dots .tm-dot'));
  var bar      = document.getElementById('tm-progress-bar');
  if (!slides.length) return;

  var current  = 0;
  var total    = slides.length;
  var INTERVAL = 5500; // ms between transitions
  var timer, rafId, startTime;

  function goTo(next) {
    slides[current].classList.remove('tm-slide--active');
    slides[current].classList.add('tm-slide--out');
    dots[current].classList.remove('tm-dot--active');

    var prev = current;
    current = next % total;

    slides[current].classList.add('tm-slide--active');
    dots[current].classList.add('tm-dot--active');

    setTimeout(function () {
      slides[prev].classList.remove('tm-slide--out');
    }, 800);
  }

  function startProgress() {
    cancelAnimationFrame(rafId);
    startTime = performance.now();
    function tick(now) {
      var elapsed = now - startTime;
      var pct = Math.min(elapsed / INTERVAL * 100, 100);
      if (bar) bar.style.width = pct + '%';
      if (elapsed < INTERVAL) {
        rafId = requestAnimationFrame(tick);
      }
    }
    rafId = requestAnimationFrame(tick);
  }

  function next() {
    goTo((current + 1) % total);
    startProgress();
  }

  // Dots are clickable
  dots.forEach(function (dot, i) {
    dot.style.cursor = 'pointer';
    dot.addEventListener('click', function () {
      if (i === current) return;
      clearInterval(timer);
      goTo(i);
      startProgress();
      timer = setInterval(next, INTERVAL);
    });
  });

  // Start when section enters viewport
  var started = false;
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting && !started) {
        started = true;
        startProgress();
        timer = setInterval(next, INTERVAL);
        io.disconnect();
      }
    }, { threshold: 0.3 });
    var section = document.getElementById('tm-section');
    if (section) io.observe(section);
  } else {
    startProgress();
    timer = setInterval(next, INTERVAL);
  }
})();
</script>

