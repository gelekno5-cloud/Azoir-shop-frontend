{%- comment -%} Testimonials — Azoir {%- endcomment -%}
<link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}"></noscript>

<section class="tm-section">
  <div class="tm-container">

    <div class="tm-header">
      <span class="tm-eyebrow">CLIENT STORIES</span>
      <h2 class="tm-title">Made for the people who wear them.</h2>
    </div>

    <div class="tm-grid">

      <article class="tm-card">
        <div class="tm-card__quote">&ldquo;</div>
        <blockquote class="tm-card__text">
          The process was unlike anything I'd experienced. They listened to every detail — the metal, the weight, the way I wanted it to feel on my hand. The ring exceeded everything I imagined.
        </blockquote>
        <footer class="tm-card__footer">
          <div class="tm-card__divider"></div>
          <span class="tm-card__name">Sophia M.</span>
          <span class="tm-card__piece">Bespoke engagement ring, 18k white gold</span>
        </footer>
      </article>

      <article class="tm-card">
        <div class="tm-card__quote">&ldquo;</div>
        <blockquote class="tm-card__text">
          I commissioned a necklace for my wife's anniversary gift. The collaboration was seamless — they translated a simple sketch into something extraordinary. She hasn't taken it off since.
        </blockquote>
        <footer class="tm-card__footer">
          <div class="tm-card__divider"></div>
          <span class="tm-card__name">James T.</span>
          <span class="tm-card__piece">Custom diamond necklace, platinum</span>
        </footer>
      </article>

      <article class="tm-card">
        <div class="tm-card__quote">&ldquo;</div>
        <blockquote class="tm-card__text">
          I knew exactly what I wanted but had no idea how to describe it. The team at Azoir understood immediately. The bracelet feels like it was born on my wrist.
        </blockquote>
        <footer class="tm-card__footer">
          <div class="tm-card__divider"></div>
          <span class="tm-card__name">Camille R.</span>
          <span class="tm-card__piece">Chain bracelet, 18k yellow gold</span>
        </footer>
      </article>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
