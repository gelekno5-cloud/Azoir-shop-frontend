{%- comment -%} Portfolio Grid — Azoir {%- endcomment -%}
<link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'homepage-sections.css' | asset_url }}"></noscript>

<section class="pg-section">
  <div class="pg-container">

    <div class="pg-header">
      <span class="pg-eyebrow">OUR WORK</span>
      <h2 class="pg-title">Recent Commissions</h2>
      <p class="pg-subtitle">Each piece is designed in close collaboration with its owner.</p>
    </div>

    <div class="pg-grid">

      {%- for block in section.blocks -%}
        {%- assign img   = block.settings.image -%}
        {%- assign vid   = block.settings.video_url -%}
        {%- assign label = block.settings.label -%}
        {%- assign meta  = block.settings.meta -%}

        <div class="pg-card" {{ block.shopify_attributes }}>
          <div class="pg-card__media">

            {%- if vid != blank -%}
              {%- comment -%} Video — autoplay, muted, loop, no controls {%- endcomment -%}
              <video
                class="pg-card__video"
                src="{{ vid }}"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>

            {%- elsif img != blank -%}
              <img
                class="pg-card__img"
                src="{{ img | image_url: width: 800 }}"
                alt="{{ img.alt | default: label | escape }}"
                width="{{ img.width }}"
                height="{{ img.height }}"
                loading="lazy"
              >

            {%- else -%}
              {%- comment -%} SVG placeholder per card index {%- endcomment -%}
              <div class="pg-card__placeholder">
                {%- case forloop.index -%}
                  {%- when 1 -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="140" cy="150" r="68" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.18"/>
                      <circle cx="140" cy="150" r="48" stroke="#0a0a0a" stroke-width="1" fill="none" opacity="0.10"/>
                      <path d="M100 150 Q140 100 180 150" stroke="#0a0a0a" stroke-width="1.2" fill="none" opacity="0.28"/>
                      <text x="140" y="236" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">RING</text>
                    </svg>
                  {%- when 2 -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="140,72 172,122 140,158 108,122" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.22"/>
                      <line x1="140" y1="60" x2="140" y2="72" stroke="#0a0a0a" stroke-width="1.5" opacity="0.3"/>
                      <circle cx="140" cy="52" r="8" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.28"/>
                      <text x="140" y="200" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">PENDANT</text>
                    </svg>
                  {%- when 3 -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M75 110 Q140 175 205 110" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.22"/>
                      <circle cx="140" cy="178" r="20" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.22"/>
                      <text x="140" y="230" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">NECKLACE</text>
                    </svg>
                  {%- when 4 -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <ellipse cx="140" cy="148" rx="82" ry="30" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.18"/>
                      <circle cx="186" cy="136" r="7" stroke="#0a0a0a" stroke-width="1.2" fill="none" opacity="0.28"/>
                      <circle cx="94" cy="136" r="7" stroke="#0a0a0a" stroke-width="1.2" fill="none" opacity="0.28"/>
                      <text x="140" y="210" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">BRACELET</text>
                    </svg>
                  {%- when 5 -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="140" cy="148" r="68" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.18"/>
                      <circle cx="140" cy="148" r="48" stroke="#0a0a0a" stroke-width="1" fill="none" opacity="0.10"/>
                      <path d="M112 148 Q140 112 168 148" stroke="#0a0a0a" stroke-width="1.2" fill="none" opacity="0.28"/>
                      <text x="140" y="236" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">RING</text>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="140,68 156,96 188,100 165,122 170,154 140,138 110,154 115,122 92,100 124,96" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.22"/>
                      <line x1="140" y1="56" x2="140" y2="68" stroke="#0a0a0a" stroke-width="1.5" opacity="0.3"/>
                      <circle cx="140" cy="48" r="8" stroke="#0a0a0a" stroke-width="1.5" fill="none" opacity="0.28"/>
                      <text x="140" y="200" text-anchor="middle" fill="#0a0a0a" font-size="8" letter-spacing="3" opacity="0.25" font-family="sans-serif">PENDANT</text>
                    </svg>
                {%- endcase -%}
              </div>
            {%- endif -%}

            {%- if label != blank or meta != blank -%}
              <div class="pg-card__overlay">
                {%- if label != blank -%}<span class="pg-card__label">{{ label }}</span>{%- endif -%}
                {%- if meta != blank -%}<span class="pg-card__meta">{{ meta }}</span>{%- endif -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}

    </div>

    <div class="pg-footer">
      <a href="{{ section.settings.cta_url | default: '/pages/commission-a-ring' }}" class="pg-cta">
        {{ section.settings.cta_text | default: 'Start your commission' }}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Portfolio Grid",
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (optional)",
          "info": "Direct URL to an .mp4 file. If set, the video plays instead of the image."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Bespoke Piece"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Material / detail",
          "default": "18k Gold"
        }
      ]
    }
  ],
  "settings": [
    { "type": "url",  "id": "cta_url",  "label": "CTA URL" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Start your commission" }
  ],
  "presets": [
    {
      "name": "Portfolio Grid",
      "blocks": [
        { "type": "card", "settings": { "label": "Bespoke Ring",       "meta": "18k White Gold" } },
        { "type": "card", "settings": { "label": "Diamond Pendant",    "meta": "Platinum" } },
        { "type": "card", "settings": { "label": "Statement Necklace", "meta": "18k Yellow Gold" } },
        { "type": "card", "settings": { "label": "Chain Bracelet",     "meta": "Sterling Silver" } },
        { "type": "card", "settings": { "label": "Engagement Ring",    "meta": "18k Rose Gold" } },
        { "type": "card", "settings": { "label": "Star Pendant",       "meta": "Platinum & Diamond" } }
      ]
    }
  ]
}
{% endschema %}
