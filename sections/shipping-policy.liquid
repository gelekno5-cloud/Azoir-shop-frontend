{%- comment -%} Shipping Policy — Azoir {%- endcomment -%}
<link rel="stylesheet" href="{{ 'pages.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'pages.css' | asset_url }}"></noscript>

<section class="shp-hero">
  <div class="ap-container">
    <span class="ap-eyebrow">Shipping &amp; Delivery</span>
    <h1 class="shp-hero__title">Handled with the same care as the piece inside.</h1>
    <p class="shp-hero__sub">Every Azoir commission ships fully insured, in our signature packaging, via tracked courier — to anywhere in the world.</p>
  </div>
</section>

<section class="shp-packaging">
  <div class="ap-container">
    <div class="shp-packaging__grid">
      <div class="shp-packaging__text">
        <h2 class="ap-section-title">The Azoir box</h2>
        <p>Your piece arrives in our matte black presentation box, lined with cotton cushioning and sealed with a ribbon. It's designed to be kept — and to arrive looking exactly as you'd expect from a piece that took weeks to make.</p>
        <p>Each order includes a certificate of authenticity, metal purity card, and care instructions on heavy stock paper.</p>
      </div>
      <div class="shp-packaging__visual" aria-hidden="true">
        <div class="shp-box-frame">
          <svg viewBox="0 0 280 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="40" y="60" width="200" height="110" rx="2" fill="#0a0a0a"/>
            <rect x="40" y="40" width="200" height="30" rx="2" fill="#151515"/>
            <line x1="140" y1="40" x2="140" y2="170" stroke="#fafaf8" stroke-width="0.6" opacity="0.12"/>
            <rect x="110" y="130" width="60" height="22" rx="1" fill="#fafaf8" fill-opacity="0.06"/>
            <text x="140" y="145" text-anchor="middle" fill="#fafaf8" font-size="5.5" letter-spacing="3" opacity="0.4" font-family="sans-serif">AZOIR &amp; CO.</text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="shp-options">
  <div class="ap-container">
    <h2 class="ap-section-title">Delivery options</h2>
    <div class="shp-options__grid">

      <div class="shp-option">
        <div class="shp-option__header">
          <h3 class="shp-option__title">United States</h3>
          <span class="shp-option__price">Complimentary</span>
        </div>
        <p class="shp-option__carrier">FedEx or UPS — signature required</p>
        <p class="shp-option__time">2–3 business days after dispatch</p>
        <p class="shp-option__detail">All domestic orders ship fully insured. A tracking number is provided as soon as your order is dispatched from our workshop.</p>
      </div>

      <div class="shp-option">
        <div class="shp-option__header">
          <h3 class="shp-option__title">International</h3>
          <span class="shp-option__price">From $38</span>
        </div>
        <p class="shp-option__carrier">DHL Express — signature required</p>
        <p class="shp-option__time">4–8 business days depending on destination</p>
        <p class="shp-option__detail">We ship to over 50 countries. Exact shipping cost and estimated transit time are confirmed at checkout. All international orders are fully insured and tracked end-to-end.</p>
      </div>

      <div class="shp-option">
        <div class="shp-option__header">
          <h3 class="shp-option__title">Rush Production</h3>
          <span class="shp-option__price">Contact us</span>
        </div>
        <p class="shp-option__carrier">Available for select commissions</p>
        <p class="shp-option__time">Timeline discussed during consultation</p>
        <p class="shp-option__detail">If you have a hard deadline — an anniversary, a proposal date, a birthday — let us know upfront. We'll be honest about whether rush production is feasible for your piece.</p>
      </div>

    </div>
  </div>
</section>

<section class="shp-timeline">
  <div class="ap-container">
    <h2 class="ap-section-title">When does shipping happen?</h2>
    <p class="shp-timeline__intro">Shipping is the final step in the commission process. Here's the full journey from commission to delivery.</p>
    <div class="shp-steps">
      <div class="shp-step">
        <span class="shp-step__dot"></span>
        <div class="shp-step__content">
          <h3 class="shp-step__title">Design &amp; approval</h3>
          <p class="shp-step__body">Sketches, CAD renders, and revisions — nothing moves to production until you approve every detail.</p>
        </div>
      </div>
      <div class="shp-step">
        <span class="shp-step__dot"></span>
        <div class="shp-step__content">
          <h3 class="shp-step__title">Handcrafted production</h3>
          <p class="shp-step__body">Casting, setting, finishing. Most pieces take 3–6 weeks in production depending on complexity.</p>
        </div>
      </div>
      <div class="shp-step">
        <span class="shp-step__dot"></span>
        <div class="shp-step__content">
          <h3 class="shp-step__title">Quality inspection</h3>
          <p class="shp-step__body">Every piece is inspected against the approved design before packaging. We don't ship anything we wouldn't wear ourselves.</p>
        </div>
      </div>
      <div class="shp-step shp-step--last">
        <span class="shp-step__dot shp-step__dot--gold"></span>
        <div class="shp-step__content">
          <h3 class="shp-step__title">Packaged &amp; dispatched</h3>
          <p class="shp-step__body">Your tracking number arrives by email as soon as your piece leaves our workshop.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="shp-faq">
  <div class="ap-container">
    <h2 class="ap-section-title">Shipping questions</h2>
    <div class="faq-list">

      <details class="faq-item">
        <summary class="faq-item__q">Do I need to be present to sign for delivery?</summary>
        <div class="faq-item__a">
          <p>Yes. All Azoir shipments require a signature on delivery. This is non-negotiable — it's how we ensure your piece arrives safely. If you miss the first attempt, your carrier will hold the package for collection or reattempt delivery. Please ensure someone is available at your delivery address.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Will I have to pay customs or import duties?</summary>
        <div class="faq-item__a">
          <p>International orders may be subject to import duties and taxes depending on your country's regulations. These charges are the responsibility of the recipient and are not included in the order total. We recommend checking with your local customs authority if you're unsure.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">What if my package is lost or damaged in transit?</summary>
        <div class="faq-item__a">
          <p>Every order ships fully insured for its declared value. In the rare event of loss or damage, we handle the insurance claim on your behalf. Please contact us within 7 days of the expected delivery date if your package hasn't arrived.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Can I change my delivery address after placing an order?</summary>
        <div class="faq-item__a">
          <p>Yes, provided the order hasn't been dispatched yet. Contact us as soon as possible with your updated address and we'll make the change. Once a tracking number has been issued, we're unable to redirect the shipment.</p>
        </div>
      </details>

    </div>
  </div>
</section>

<script>
(function () {
  document.querySelectorAll('.shp-faq .faq-item').forEach(function (item) {
    item.addEventListener('toggle', function () {
      if (item.open) {
        document.querySelectorAll('.shp-faq .faq-item[open]').forEach(function (other) {
          if (other !== item) other.removeAttribute('open');
        });
      }
    });
  });
})();
</script>

<section class="ap-cta-band">
  <div class="ap-container">
    <h2 class="ap-cta-band__title">Questions about your order?</h2>
    <p class="ap-cta-band__sub">We're available to help at every stage — from first commission to final delivery.</p>
    <a href="/pages/contact" class="ap-cta-band__btn">Get in touch</a>
  </div>
</section>

{% schema %}
{
  "name": "Shipping Policy",
  "settings": [],
  "presets": [{ "name": "Shipping Policy" }]
}
{% endschema %}
