{% doc %}
  @prompt
    Multicolumn
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multicolumn-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-multicolumn-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-multicolumn-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-multicolumn-heading-{{ ai_gen_id }} {
    margin: 0 0 12px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-multicolumn-subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.6;
  }

  .ai-multicolumn-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
    margin-bottom: {{ block.settings.button_spacing }}px;
  }

  .ai-multicolumn-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.content_alignment }};
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-multicolumn-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin: 0 auto;
    max-width: {{ block.settings.image_width }}px;
  }

  .ai-multicolumn-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multicolumn-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multicolumn-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-multicolumn-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
    color: {{ block.settings.icon_color }};
  }

  .ai-multicolumn-item-heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.item_heading_size }}px;
    font-weight: 600;
  }

  .ai-multicolumn-item-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.item_text_size }}px;
    line-height: 1.6;
  }

  .ai-multicolumn-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-multicolumn-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-multicolumn-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.column_gap | times: 0.75 }}px;
    }

    .ai-multicolumn-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-multicolumn-item-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_heading_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<multicolumn-block-{{ ai_gen_id }} class="ai-multicolumn-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multicolumn-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-multicolumn-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-multicolumn-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-multicolumn-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-multicolumn-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'column_' | append: i | append: '_image'
          assign icon_key = 'column_' | append: i | append: '_icon'
          assign heading_key = 'column_' | append: i | append: '_heading'
          assign text_key = 'column_' | append: i | append: '_text'
          
          assign column_image = block.settings[image_key]
          assign column_icon = block.settings[icon_key]
          assign column_heading = block.settings[heading_key]
          assign column_text = block.settings[text_key]
        %}

        {% if column_heading != blank or column_text != blank or column_image != blank or column_icon != blank %}
          <div class="ai-multicolumn-item-{{ ai_gen_id }}">
            {% if block.settings.media_type == 'image' %}
              <div class="ai-multicolumn-image-wrapper-{{ ai_gen_id }}">
                {% if column_image != blank %}
                  <img
                    src="{{ column_image | image_url: width: 600 }}"
                    alt="{{ column_image.alt | escape }}"
                    loading="lazy"
                    width="{{ column_image.width }}"
                    height="{{ column_image.height }}"
                    class="ai-multicolumn-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-multicolumn-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            {% elsif block.settings.media_type == 'icon' and column_icon != blank %}
              <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
                {{ column_icon }}
              </div>
            {% endif %}

            {% if column_heading != blank %}
              <h3 class="ai-multicolumn-item-heading-{{ ai_gen_id }}">{{ column_heading }}</h3>
            {% endif %}

            {% if column_text != blank %}
              <div class="ai-multicolumn-item-text-{{ ai_gen_id }}">{{ column_text }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.button_label != blank %}
      <div class="ai-multicolumn-button-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-multicolumn-button-{{ ai_gen_id }}">
          {{ block.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</multicolumn-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MulticolumnBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('multicolumn-block-{{ ai_gen_id }}', MulticolumnBlock{{ ai_gen_id }});
  })();
</script>

