{{ 'commission-rings.css' | asset_url | stylesheet_tag }}

{% assign slide_blocks = section.blocks | where: 'type', 'slide' %}
<section class="commission-page commission-two-col" id="commission-form">
  <div class="commission-two-col__grid">
    <aside class="commission-two-col__media">
      <div class="commission-two-col__media-sticky">
        <div class="commission-two-col__slideshow" data-slideshow>
          {% if slide_blocks.size > 0 %}
            {% if slide_blocks.size > 1 %}
              <button type="button" class="commission-two-col__slideshow-nav commission-two-col__slideshow-nav--prev" data-slide-prev aria-label="Previous slide">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button type="button" class="commission-two-col__slideshow-nav commission-two-col__slideshow-nav--next" data-slide-next aria-label="Next slide">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            {% endif %}
            {% for block in slide_blocks %}
              <div class="commission-two-col__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                {% if block.settings.video != blank %}
                  <div class="commission-two-col__slide-video">
                    {% if block.settings.video.host == 'youtube' %}
                      {{
                        block.settings.video
                        | external_video_url: autoplay: true, loop: true, playlist: block.settings.video.external_id, mute: '1', controls: false
                        | external_video_tag: class: 'commission-two-col__video-embed'
                      }}
                    {% elsif block.settings.video.host == 'vimeo' %}
                      {{
                        block.settings.video
                        | external_video_url: autoplay: true, loop: true, mute: '1', controls: false
                        | external_video_tag: class: 'commission-two-col__video-embed'
                      }}
                    {% else %}
                      {{
                        block.settings.video
                        | video_tag: image_size: '1200x', autoplay: true, loop: true, controls: false, muted: true, playsinline: true, class: 'commission-two-col__video-native'
                      }}
                    {% endif %}
                  </div>
                {% elsif block.settings.image != blank %}
                  {% if forloop.first %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'eager', alt: block.settings.alt | default: 'Commission' | escape }}
                {% else %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.alt | default: 'Commission' | escape }}
                {% endif %}
                {% else %}
                  <div class="commission-two-col__slide-placeholder"></div>
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            <div class="commission-two-col__slide is-active">
              <div class="commission-two-col__slide-placeholder"></div>
            </div>
          {% endif %}
        </div>
      </div>
    </aside>

    <div class="commission-two-col__form">
      <div class="commission-form__inner commission-rings-form__inner">
        {% if section.settings.page_title != blank %}
          <h1 class="commission-two-col__page-title">{{ section.settings.page_title | escape }}</h1>
        {% endif %}
        {% if section.settings.page_subtitle != blank %}
          <p class="commission-two-col__page-subtitle">{{ section.settings.page_subtitle | escape }}</p>
        {% endif %}
        <p class="commission-rings-form__step-label"><span class="commission-rings-form__step-num">01</span></p>
        <h2 class="commission-form__heading">{{ section.settings.heading | default: 'Defining Your Vision' | escape }}</h2>
        <p class="commission-form__subheading commission-rings-form__timeline">Timeline: {{ section.settings.timeline | default: '1–2 days' | escape }}</p>
        <p class="commission-form__subheading">{{ section.settings.subheading | default: 'Share your concept — the symbols, proportions, mood, references, or even just a rough direction.' | escape }}</p>

        <form class="commission-form__form commission-rings-form__form" id="cr2c-form" novalidate>
          <div class="commission-form__message commission-form__message--error" id="cr2c-form-error" role="alert" hidden></div>

          <div class="commission-rings-form__section">
            <h3 class="commission-rings-form__section-title">Describe Your Project</h3>
            <div class="commission-form__row">
              <label for="cr2c-describe" class="commission-form__label">{{ section.settings.label_describe | default: 'Describe your vision' | escape }}</label>
              <textarea
                id="cr2c-describe"
                name="notes"
                class="commission-form__textarea"
                rows="4"
              ></textarea>
            </div>
          </div>

          <div class="commission-rings-form__section">
            <h3 class="commission-rings-form__section-title">Upload Reference Photos</h3>
            <div class="commission-form__row">
              <div class="cr-upload" id="cr2c-upload">
                <div class="cr-upload__zone" id="cr2c-upload-zone" tabindex="0" role="button" aria-label="Upload reference photos">
                  <input type="file" id="cr2c-file-input" accept="image/*" multiple class="cr-upload__input" tabindex="-1">
                  <div class="cr-upload__icon-wrap">
                    <svg class="cr-upload__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M17 8L12 3L7 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 3V15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <p class="cr-upload__label">Drop your photos here</p>
                  <p class="cr-upload__sublabel">Share inspiration images, sketches, or references</p>
                  <span class="cr-upload__browse-btn">Browse files</span>
                  <p class="cr-upload__hint">JPG &middot; PNG &middot; WEBP &nbsp;&bull;&nbsp; Up to 5 photos &nbsp;&bull;&nbsp; 10 MB each</p>
                </div>
                <div class="cr-upload__previews" id="cr2c-upload-previews" hidden></div>
              </div>
              <input type="hidden" name="reference_links" id="cr2c-reference-links" value="">
              <p class="commission-form__upload-note">{{ section.settings.upload_note | default: "Your photos are uploaded securely when you submit the form. We use them only to understand your vision." }}</p>
              <p class="commission-form__upload-note cr-upload__error" id="cr2c-upload-error" hidden></p>
            </div>
          </div>

          <div class="commission-rings-form__section">
            <h3 class="commission-rings-form__section-title">Metal & Stones</h3>
            <div class="commission-form__row">
              <label for="cr2c-metal" class="commission-form__label commission-form__label--required">Select your preferred metal</label>
              <select id="cr2c-metal" name="metal" class="commission-form__select" required>
                <option value="">Select metal *</option>
                <option value="Sterling Silver">Sterling Silver</option>
                <option value="10K Yellow Gold">10K Yellow Gold</option>
                <option value="10K White Gold">10K White Gold</option>
                <option value="10K Rose Gold">10K Rose Gold</option>
                <option value="14K Yellow Gold">14K Yellow Gold</option>
                <option value="14K White Gold">14K White Gold</option>
                <option value="14K Rose Gold">14K Rose Gold</option>
                <option value="18K Yellow Gold">18K Yellow Gold</option>
                <option value="18K White Gold">18K White Gold</option>
                <option value="18K Rose Gold">18K Rose Gold</option>
                <option value="Platinum">Platinum</option>
                <option value="24K Yellow Gold">24K Yellow Gold</option>
              </select>
            </div>
            <div class="commission-form__row">
              <label class="commission-form__label">Does your design contain any stones?</label>
              <div class="cr-stone-btns" id="cr2c-stone-btns" role="group" aria-label="Stone selection">
                <button type="button" class="cr-stone-btn" data-value="No Stones">No Stones</button>
                <button type="button" class="cr-stone-btn" data-value="Lab-Grown Diamonds">Lab-Grown Diamonds</button>
                <button type="button" class="cr-stone-btn" data-value="Natural Diamonds">Natural Diamonds</button>
              </div>
              <input type="hidden" name="stones" id="cr2c-stones-hidden" value="">
              <div class="commission-form__row" id="cr2c-stone-other-row" style="margin-top:0.75rem;margin-bottom:0;">
                <label for="cr2c-stones-other" class="commission-form__label">Other stone — describe below</label>
                <input
                  type="text"
                  id="cr2c-stones-other"
                  class="commission-form__input"
                  placeholder="e.g. Sapphire, Ruby, Emerald…"
                >
              </div>
            </div>
          </div>

          <div class="commission-rings-form__section">
            <h3 class="commission-rings-form__section-title">Contact Info</h3>
            <p class="commission-rings-form__section-desc">So we can reach out with your quote and any questions.</p>
            <div class="commission-form__row">
